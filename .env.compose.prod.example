APP_URL=https://api.example.invalid
NGINX_HTTP_PORT=80

BACKEND_IMAGE=ghcr.io/example/mediconnect-api
BACKEND_IMAGE_TAG=latest

DB_CONNECTION=pgsql
DB_HOST=postgres.example.invalid
DB_PORT=5432
DB_DATABASE=mediconnect
DB_USERNAME=mediconnect
DB_PASSWORD=replace-via-secret-manager
DB_SSLMODE=require

REDIS_HOST=redis.example.invalid
REDIS_PORT=6379
REDIS_PASSWORD=replace-via-secret-manager
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_HOST=smtp.example.invalid
MAIL_PORT=587
MAIL_USERNAME=alerts@example.invalid
MAIL_PASSWORD=replace-via-secret-manager
MAIL_ENCRYPTION=tls

REVERB_APP_ID=mediconnect
REVERB_APP_KEY=replace-via-secret-manager
REVERB_APP_SECRET=replace-via-secret-manager
REVERB_HOST=ws.example.invalid
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_ALLOWED_ORIGINS=https://app.example.invalid
REVERB_SERVER_PORT_FORWARD=8081

METRICS_TOKEN=replace-via-secret-manager
METRICS_REDIS_CONNECTION=cache
METRICS_QUEUE_NAMES=default

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

COTURN_STUN_URLS=stun:turn.example.invalid:3478
COTURN_TURN_URLS=turn:turn.example.invalid:3478?transport=udp,turns:turn.example.invalid:5349?transport=tcp
COTURN_SHARED_SECRET=replace-via-secret-manager
COTURN_REALM=teleconsultation.example.invalid

DOCUMENTS_AI_DRIVER=heuristic
DOCUMENTS_DOCUMENT_CHAT_DRIVER=heuristic
DOCUMENTS_AI_PROVIDER=medical_api
DOCUMENTS_AI_BASE_URL=https://ai.example.invalid/proxy/8097
DOCUMENTS_AI_MODEL=II-Medical-8B
DOCUMENTS_AI_GENERATE_PATH=/generate
DOCUMENTS_AI_CHAT_PATH=/chat
DOCUMENTS_AI_TIMEOUT_SECONDS=45
DOCUMENTS_AI_MAX_NEW_TOKENS=1024
DOCUMENTS_AI_TEMPERATURE=0
DOCUMENTS_AI_TOP_P=0.9
DOCUMENTS_AI_REPETITION_PENALTY=1.1
DOCUMENTS_AI_PROMPT_TEXT_MAX_CHARS=2600

TRUSTED_PROXIES=*
