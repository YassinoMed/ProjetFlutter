APP_NAME="MediConnect Pro API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug
SECURITY_LOG_LEVEL=info
SECURITY_LOG_DAYS=90
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_RETENTION_DAYS=365
ACTIVITY_LOGGER_TABLE_NAME=activity_log
ACTIVITY_LOGGER_DB_CONNECTION=
ACTIVITY_LOG_NAME=security

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mediconnect
DB_USERNAME=mediconnect
DB_PASSWORD=secret

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Reverb (native Laravel WebSocket) ────────────────────
REVERB_APP_ID=mediconnect
REVERB_APP_KEY=mediconnect-key
REVERB_APP_SECRET=mediconnect-secret
REVERB_HOST=app
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mediconnect.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── JWT (tymon/jwt-auth) ────────────────────────────────
JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=10080
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_PASSPHRASE=
JWT_ALGO=HS256
JWT_LEEWAY=0
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

# ── Firebase Cloud Messaging ────────────────────────────
FIREBASE_CREDENTIALS=storage/app/firebase-service-account.json
FIREBASE_PROJECT_ID=

# ── OpenTelemetry ────────────────────────────────────────
OTEL_ENABLED=true
OTEL_SERVICE_NAME=mediconnect-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=always_on
OTEL_LOG_LEVEL=info

# ── Data Minimization (RGPD) ────────────────────────────
CHAT_MESSAGE_TTL_DAYS=730
MEDICAL_RECORD_TTL_DAYS=3650
DATA_RETENTION_WARNING_DAYS=30
