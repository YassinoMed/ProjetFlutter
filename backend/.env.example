APP_NAME="MediConnect Pro API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_STACK=json_stderr,security
LOG_LEVEL=debug
LOG_DAILY_DAYS=14
SECURITY_LOG_LEVEL=info
SECURITY_LOG_DAYS=90
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_RETENTION_DAYS=365
ACTIVITY_LOGGER_TABLE_NAME=activity_log
ACTIVITY_LOGGER_DB_CONNECTION=
ACTIVITY_LOG_NAME=security

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mediconnect
DB_USERNAME=mediconnect
DB_PASSWORD=local-dev-only-db-password
DB_SSLMODE=prefer

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Reverb (native Laravel WebSocket) ────────────────────
REVERB_APP_ID=mediconnect
REVERB_APP_KEY=local-dev-only-reverb-key
REVERB_APP_SECRET=local-dev-only-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081
REVERB_ALLOWED_ORIGINS=http://localhost:8080

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mediconnect.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── JWT (tymon/jwt-auth) ────────────────────────────────
JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=10080
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_PASSPHRASE=
JWT_ALGO=HS256
JWT_LEEWAY=0
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

# ── Firebase Cloud Messaging ────────────────────────────
FIREBASE_CREDENTIALS=storage/app/firebase-service-account.json
FIREBASE_PROJECT_ID=

# ── OpenTelemetry ────────────────────────────────────────
OTEL_ENABLED=true
OTEL_SERVICE_NAME=mediconnect-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=always_on
OTEL_LOG_LEVEL=info

TRUSTED_PROXIES=*
RUN_MIGRATIONS=false
CACHE_LARAVEL_BOOTSTRAP=false
METRICS_ENABLED=true
METRICS_TOKEN=local-dev-only-metrics-token
METRICS_REDIS_CONNECTION=cache
METRICS_QUEUE_NAMES=default

# ── Data Minimization (RGPD) ────────────────────────────
CHAT_MESSAGE_TTL_DAYS=730
MEDICAL_RECORD_TTL_DAYS=3650
DATA_RETENTION_WARNING_DAYS=30

# ── MediConnect secure communications ──────────────────
MEDICONNECT_PRESENCE_FRESHNESS_SECONDS=90
MEDICONNECT_MESSAGE_RETENTION_DAYS=730
MEDICONNECT_CALL_RING_TIMEOUT_SECONDS=45

# ── Coturn / ICE servers ───────────────────────────────
COTURN_STUN_URLS=stun:turn.example.invalid:3478
COTURN_TURN_URLS=turn:turn.example.invalid:3478?transport=udp,turns:turn.example.invalid:5349?transport=tcp
COTURN_STATIC_USERNAME=
COTURN_STATIC_PASSWORD=
COTURN_SHARED_SECRET=
COTURN_REALM=teleconsultation.mediconnect.local
COTURN_CREDENTIAL_TTL_SECONDS=3600

# ── Medical documents AI module ─────────────────────────
DOCUMENTS_DISK=local
DOCUMENTS_DIRECTORY=medical-documents
DOCUMENTS_MAX_UPLOAD_KB=12288
DOCUMENTS_PDF_TEXT_DRIVER=pdftotext
DOCUMENTS_OCR_DRIVER=none
DOCUMENTS_OCR_LANGUAGES=fra+eng
DOCUMENTS_PDF_OCR_MAX_PAGES=3
DOCUMENTS_AI_DRIVER=heuristic
# heuristic by default. Use "http" only after explicit medical-data approval.
DOCUMENTS_DOCUMENT_CHAT_DRIVER=heuristic
DOCUMENTS_AI_PROVIDER=medical_api
DOCUMENTS_AI_BASE_URL=
DOCUMENTS_AI_API_KEY=
DOCUMENTS_AI_MODEL=II-Medical-8B
DOCUMENTS_AI_GENERATE_PATH=/generate
DOCUMENTS_AI_CHAT_PATH=/chat
DOCUMENTS_AI_TIMEOUT_SECONDS=45
DOCUMENTS_AI_MAX_NEW_TOKENS=1024
DOCUMENTS_AI_TEMPERATURE=0
DOCUMENTS_AI_TOP_P=0.9
DOCUMENTS_AI_REPETITION_PENALTY=1.1
DOCUMENTS_AI_PROMPT_TEXT_MAX_CHARS=2600

# ── S3 / Object Storage ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
