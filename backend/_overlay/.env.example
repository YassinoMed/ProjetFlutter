APP_NAME="MediConnect Pro API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug
SECURITY_LOG_LEVEL=info
SECURITY_LOG_DAYS=90
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_RETENTION_DAYS=365
ACTIVITY_LOGGER_TABLE_NAME=activity_log
ACTIVITY_LOGGER_DB_CONNECTION=
ACTIVITY_LOG_NAME=security

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mediconnect
DB_USERNAME=mediconnect
DB_PASSWORD=secret

BROADCAST_CONNECTION=pusher
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

PUSHER_APP_ID=local
PUSHER_APP_KEY=local
PUSHER_APP_SECRET=local
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=app
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_USE_TLS=false
WEBSOCKETS_PORT=6001
WEBSOCKETS_PATH=/app

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mediconnect.local"
MAIL_FROM_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=10080
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

FIREBASE_CREDENTIALS=storage/app/firebase-service-account.json
FIREBASE_PROJECT_ID=
